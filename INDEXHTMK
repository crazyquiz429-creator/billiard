function toggleExtras(id){
  if(extrasOpen.has(id))extrasOpen.delete(id);
  else extrasOpen.add(id);
  const eb=document.getElementById('extras-'+id);
  if(eb)eb.classList.toggle('open');
}

function addExtra(tableId,catalogIdx){
  const t=timers[tableId];const p=CATALOG[catalogIdx];
  const existing=t.extras.find(e=>e.name===p.name);
  if(existing)existing.qty++;
  else t.extras.push({name:p.name,price:p.price,qty:1});
  extrasOpen.add(tableId);render();
}

function addCustomExtra(tableId){
  const nameEl=document.getElementById('cname-'+tableId);
  const priceEl=document.getElementById('cprice-'+tableId);
  const name=nameEl?.value.trim();
  const price=parseInt(priceEl?.value);
  if(!name||!price||price<=0)return;
  timers[tableId].extras.push({name,price,qty:1});
  extrasOpen.add(tableId);render();
}

function changeQty(tableId,extraIdx,delta){
  const e=timers[tableId].extras[extraIdx];
  e.qty=Math.max(1,e.qty+delta);
  extrasOpen.add(tableId);render();
}

function removeExtra(tableId,extraIdx){
  timers[tableId].extras.splice(extraIdx,1);
  extrasOpen.add(tableId);render();
}

function changePassword(){
  const oldPass=document.getElementById('oldPassInput').value;
  const newPass=document.getElementById('newPassInput').value;
  const confirmPass=document.getElementById('confirmPassInput').value;
  const errEl=document.getElementById('passChangeError');
  const okEl=document.getElementById('passChangeOk');
  errEl.style.display='none';okEl.style.display='none';
  if(oldPass!==ADMIN_CODE){errEl.textContent='⚠ Joriy parol noto\'g\'ri';errEl.style.display='block';return;}
  if(newPass.length<4){errEl.textContent='⚠ Yangi parol kamida 4 ta belgi bo\'lishi kerak';errEl.style.display='block';return;}
  if(newPass!==confirmPass){errEl.textContent='⚠ Parollar mos kelmadi';errEl.style.display='block';return;}
  ADMIN_CODE=newPass;localStorage.setItem('adminCode',ADMIN_CODE);
  okEl.textContent='✓ Parol muvaffaqiyatli o\'zgartirildi!';okEl.style.display='block';
  document.getElementById('oldPassInput').value='';
  document.getElementById('newPassInput').value='';
  document.getElementById('confirmPassInput').value='';
}

function renderCatalogEditor(){
  const root=document.getElementById('catalogEditor');
  if(!root)return;root.innerHTML='';
  CATALOG.forEach((item,index)=>{
    const row=document.createElement('div');row.className='catalog-item';
    row.innerHTML=`<input class="emoji" type="text" placeholder="Emoji"><input class="name" type="text" placeholder="Nomi"><input class="price" type="number" placeholder="Narx"><button class="btn btn-red">✕</button>`;
    row.querySelector('.emoji').value=item.emoji||'';
    row.querySelector('.name').value=item.name||'';
    row.querySelector('.price').value=item.price||'';
    row.querySelector('.emoji').addEventListener('input',e=>{CATALOG[index].emoji=e.target.value});
    row.querySelector('.name').addEventListener('input',e=>{CATALOG[index].name=e.target.value});
    row.querySelector('.price').addEventListener('input',e=>{CATALOG[index].price=parseInt(e.target.value)||0});
    row.querySelector('.btn-red').addEventListener('click',()=>{deleteCatalogItem(index)});
    root.appendChild(row);
  });
}

function addCatalogItem(){CATALOG.push({emoji:'🛒',name:'',price:0});renderCatalogEditor()}

function deleteCatalogItem(index){
  if(!confirm('Mahsulot o\'chirilsinmi?'))return;
  CATALOG.splice(index,1);localStorage.setItem('catalog',JSON.stringify(CATALOG));
  renderCatalogEditor();render();
}

function saveCatalogChanges(){
  const items=document.querySelectorAll('.catalog-item');const newCatalog=[];
  items.forEach(item=>{
    const emoji=item.querySelector('.emoji').value.trim()||'🛒';
    const name=item.querySelector('.name').value.trim();
    const price=parseInt(item.querySelector('.price').value)||0;
    if(name&&price>0)newCatalog.push({emoji,name,price});
  });
  CATALOG=newCatalog;localStorage.setItem('catalog',JSON.stringify(CATALOG));
  alert('Mahsulotlar saqlandi!');render();renderCatalogEditor();
}

function checkAdminCode(){
  const val=document.getElementById('adminCodeInput').value;
  if(val===ADMIN_CODE){document.getElementById('adminLock').style.display='none';}
  else{document.getElementById('adminError').style.display='block';document.getElementById('adminCodeInput').value='';}
}

document.getElementById('adminCodeInput').addEventListener('keydown',e=>{if(e.key==='Enter')checkAdminCode()});

renderCatalogEditor();
initTimers();
render();
setInterval(render,1000);
</script>
