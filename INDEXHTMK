<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ashurali Billiard</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}

:root{
  --gold:#d4a843;
  --gold2:#f0c84a;
  --gold3:#8a6820;
  --green:#00e676;
  --green2:#00b050;
  --red:#ff3d3d;
  --orange:#ff8c00;
  --bg:#050709;
  --bg2:#080c10;
  --surface:#0c1218;
  --surface2:#111a24;
  --border:#172030;
  --border2:#1e2d40;
  --text:#ccd8e4;
  --text2:#6a8aaa;
  --felt:#0a1f0f;
  --felt2:#0d2812;
  --ball-red:#cc2200;
  --ball-yellow:#e8c300;
  --ball-blue:#0044cc;
  --f-display:'Bebas Neue',sans-serif;
  --f-ui:'Rajdhani',sans-serif;
  --f-mono:'Share Tech Mono',monospace;
}

html,body{height:100%;overflow-x:hidden}

body{
  background:var(--bg);
  color:var(--text);
  font-family:var(--f-ui);
  min-height:100vh;
  background-image:
    radial-gradient(ellipse 100% 60% at 50% -5%, rgba(212,168,67,0.06) 0%, transparent 55%),
    radial-gradient(ellipse 50% 50% at 0% 80%, rgba(0,230,118,0.03) 0%, transparent 50%),
    radial-gradient(ellipse 40% 40% at 100% 20%, rgba(0,68,204,0.04) 0%, transparent 50%);
}

/* ═══ NOISE GRAIN OVERLAY ═══ */
body::before{
  content:'';
  position:fixed;inset:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events:none;z-index:0;opacity:0.4;
}

/* ═══ BILLIARD TABLE FELT STRIPE ═══ */
.felt-stripe{
  height:3px;
  background:linear-gradient(90deg, transparent, var(--green2), var(--green), var(--green2), transparent);
  opacity:0.6;
}

/* ═══ HEADER ═══ */
.header{
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:14px 32px;
  background:rgba(5,7,9,0.96);
  border-bottom:1px solid var(--border);
  position:sticky;top:0;z-index:200;
  backdrop-filter:blur(20px);
}
.logo{display:flex;align-items:center;gap:16px}
.logo-emblem{
  width:48px;height:48px;
  background:radial-gradient(circle at 40% 35%, #1e3a1e, #0a1f0f);
  border:1px solid var(--gold3);
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:22px;
  box-shadow:0 0 20px rgba(212,168,67,0.25), inset 0 1px 0 rgba(212,168,67,0.1);
  position:relative;overflow:hidden;
}
.logo-emblem::after{
  content:'';position:absolute;
  top:-50%;left:-50%;width:200%;height:200%;
  background:conic-gradient(transparent 0deg,rgba(212,168,67,0.06) 90deg,transparent 180deg,rgba(212,168,67,0.06) 270deg,transparent 360deg);
  animation:spin 8s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg)}}
.logo-text{line-height:1.1}
.logo-text h1{
  font-family:var(--f-display);
  font-size:26px;
  letter-spacing:4px;
  color:var(--gold);
  text-shadow:0 0 30px rgba(212,168,67,0.4);
}
.logo-text span{
  font-size:9px;color:var(--text2);
  letter-spacing:5px;text-transform:uppercase;
}
.header-actions{display:flex;gap:8px;align-items:center}

/* ═══ BUTTONS ═══ */
.btn{
  padding:7px 18px;border-radius:4px;
  font-size:11px;font-weight:700;cursor:pointer;
  font-family:var(--f-display);letter-spacing:2px;
  text-transform:uppercase;transition:all 0.15s;border:none;
}
.btn:active{transform:scale(0.96)}
.btn-ghost{background:transparent;border:1px solid var(--border2);color:var(--text2)}
.btn-ghost:hover{border-color:var(--gold3);color:var(--gold)}
.btn-gold{background:linear-gradient(135deg,var(--gold),var(--gold3));color:#000;font-weight:700}
.btn-gold:hover{background:linear-gradient(135deg,var(--gold2),var(--gold))}
.btn-red{background:transparent;border:1px solid rgba(255,61,61,0.35);color:var(--red)}
.btn-red:hover{background:rgba(255,61,61,0.08)}
.btn-green{background:linear-gradient(135deg,var(--green2),#007a30);color:#000;font-weight:700}
.btn-green:hover{filter:brightness(1.15)}
.btn-amber{background:transparent;border:1px solid rgba(212,168,67,0.35);color:var(--gold)}
.btn-amber:hover{background:rgba(212,168,67,0.08)}

/* ═══ QUICK SETTINGS BAR ═══ */
.qbar{
  display:flex;align-items:center;gap:28px;
  padding:9px 32px;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  flex-wrap:wrap;
}
.qbar-group{display:flex;align-items:center;gap:8px}
.qbar label{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:2px}
.qbar input[type=number]{
  background:#050c12;border:1px solid var(--border2);
  color:var(--text);padding:5px 10px;border-radius:4px;
  font-size:13px;font-family:var(--f-mono);width:95px;outline:none;
}
.qbar input:focus{border-color:var(--gold)}
.qbar-unit{font-size:10px;color:var(--text2);letter-spacing:1px}

/* ═══ STATS BAR ═══ */
.statsbar{
  display:grid;grid-template-columns:repeat(4,1fr);
  border-bottom:1px solid var(--border);
  background:var(--bg2);
}
.stat{padding:11px 22px;border-right:1px solid var(--border);text-align:center}
.stat:last-child{border-right:none}
.stat-lbl{font-size:9px;color:var(--text2);text-transform:uppercase;letter-spacing:2.5px;margin-bottom:3px}
.stat-val{font-family:var(--f-mono);font-size:18px;color:var(--gold);font-weight:700}
@media(max-width:700px){.statsbar{grid-template-columns:repeat(2,1fr)}}

/* ═══ GRID ═══ */
.grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;padding:22px 26px;
  max-width:1900px;margin:0 auto;
}
@media(max-width:1150px){.grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:720px){.grid{grid-template-columns:1fr;padding:14px}}

/* ═══ CARD — BILLIARD TABLE FEEL ═══ */
.card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:8px;
  overflow:hidden;
  transition:border-color 0.3s, box-shadow 0.3s;
  position:relative;
}
.card::before{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(255,255,255,0.015) 0%,transparent 50%);
  pointer-events:none;border-radius:8px;
}
.card.running{
  border-color:var(--green2);
  box-shadow:0 0 0 1px rgba(0,230,118,0.1), 0 0 32px rgba(0,230,118,0.06);
}
.card.overtime{
  border-color:var(--orange);
  box-shadow:0 0 0 1px rgba(255,140,0,0.15), 0 0 32px rgba(255,140,0,0.08);
  animation:overtime-glow 2s ease-in-out infinite;
}
@keyframes overtime-glow{
  0%,100%{box-shadow:0 0 0 1px rgba(255,140,0,0.15), 0 0 32px rgba(255,140,0,0.08)}
  50%{box-shadow:0 0 0 1px rgba(255,140,0,0.3), 0 0 48px rgba(255,140,0,0.15)}
}

/* ═══ PULSING DOT ═══ */
.pulse{position:absolute;top:13px;right:13px;width:7px;height:7px;border-radius:50%;background:var(--border2)}
.running .pulse{background:var(--green);animation:pdot 1.5s ease-in-out infinite}
.overtime .pulse{background:var(--orange);animation:pdot 0.7s ease-in-out infinite}
@keyframes pdot{0%,100%{opacity:1;transform:scale(1);box-shadow:0 0 0 0 currentColor}50%{opacity:0.4;transform:scale(1.6);box-shadow:0 0 0 4px transparent}}

/* ═══ CARD HEADER ═══ */
.card-head{
  display:flex;align-items:center;justify-content:space-between;
  padding:11px 16px 9px;
  border-bottom:1px solid var(--border);
  background:rgba(0,0,0,0.3);
}
.table-name{
  font-family:var(--f-display);
  font-size:15px;letter-spacing:4px;
  color:var(--gold);text-transform:uppercase;
  cursor:pointer;
}
.table-name:hover{color:var(--gold2)}
.status-pill{
  font-size:8px;letter-spacing:2px;text-transform:uppercase;
  padding:2px 10px;border-radius:2px;font-weight:700;
  font-family:var(--f-display);
  background:rgba(255,255,255,0.04);color:var(--text2);
  border:1px solid var(--border2);
}
.running .status-pill{background:rgba(0,230,118,0.1);color:var(--green);border-color:rgba(0,230,118,0.25)}
.overtime .status-pill{background:rgba(255,140,0,0.1);color:var(--orange);border-color:rgba(255,140,0,0.25)}

/* ═══ TIME DISPLAY ═══ */
.time-area{
  padding:16px 18px 8px;
  display:flex;align-items:center;justify-content:space-between;
  background:linear-gradient(180deg,rgba(0,0,0,0.2),transparent);
}
.time-num{
  font-family:var(--f-mono);
  font-size:48px;font-weight:400;
  color:var(--text);line-height:1;
  letter-spacing:3px;transition:color 0.3s;
}
.running .time-num,.overtime .time-num{color:var(--green)}
.overtime .time-num{color:var(--orange)}
.time-meta{
  font-size:9px;color:var(--text2);
  letter-spacing:2px;text-transform:uppercase;margin-top:4px;
}

/* Countdown display */
.countdown-display{
  text-align:right;
}
.countdown-lbl{font-size:8px;color:var(--text2);letter-spacing:2px;text-transform:uppercase;margin-bottom:2px}
.countdown-val{
  font-family:var(--f-mono);font-size:22px;
  color:var(--text2);transition:color 0.3s;
}
.countdown-val.warn{color:var(--orange);animation:blink-warn 1s ease-in-out infinite}
.countdown-val.over{color:var(--red);animation:blink-warn 0.5s ease-in-out infinite}
@keyframes blink-warn{0%,100%{opacity:1}50%{opacity:0.4}}

/* ═══ PROGRESS / LIMIT BAR ═══ */
.prog-wrap{height:3px;background:var(--border);margin:0}
.prog-fill{height:100%;background:var(--green);transition:width 0.8s linear;max-width:100%}
.prog-fill.warn{background:var(--orange)}
.prog-fill.over{background:var(--red)}

/* ═══ PRICE ROW ═══ */
.price-row{
  display:flex;align-items:flex-end;justify-content:space-between;
  padding:8px 18px 10px;
}
.price-detail{font-size:10px;color:var(--text2);text-transform:uppercase;letter-spacing:1.5px;line-height:1.6}
.price-detail span{color:var(--text);font-family:var(--f-mono);font-size:12px}
.price-total-lbl{font-size:8px;color:var(--text2);letter-spacing:3px;text-transform:uppercase;margin-bottom:1px;text-align:right}
.price-total{font-family:var(--f-mono);font-size:20px;font-weight:400;color:var(--gold);text-align:right}
.overtime .price-total{color:var(--orange)}

/* ═══ CONTROLS ═══ */
.controls{display:flex;gap:7px;padding:0 14px 13px}
.btn-start{
  flex:1;height:40px;border-radius:4px;
  font-size:14px;font-weight:700;
  font-family:var(--f-display);letter-spacing:3px;
  text-transform:uppercase;cursor:pointer;border:none;
  background:linear-gradient(135deg,var(--green2),#006028);
  color:#000;transition:all 0.15s;
}
.btn-start:hover{filter:brightness(1.15)}
.btn-start.active{
  background:linear-gradient(135deg,#cc1010,#7a0808);
  color:#fff;
}
.btn-start:active{transform:scale(0.97)}
.btn-icon{
  width:40px;height:40px;border-radius:4px;
  border:1px solid var(--border2);background:transparent;
  color:var(--text2);cursor:pointer;font-size:15px;
  display:flex;align-items:center;justify-content:center;
  transition:all 0.15s;
}
.btn-icon:hover{border-color:var(--text2);color:var(--text)}
.btn-icon:active{transform:scale(0.95)}

/* ═══ TIME LIMIT ROW ═══ */
.limit-row{
  display:flex;align-items:center;gap:8px;
  padding:0 14px 10px;
}
.limit-row label{font-size:9px;color:var(--text2);text-transform:uppercase;letter-spacing:2px;white-space:nowrap}
.limit-input{
  width:70px;background:#06080c;
  border:1px solid var(--border2);color:var(--text);
  padding:4px 8px;border-radius:4px;font-size:12px;
  font-family:var(--f-mono);outline:none;
}
.limit-input:focus{border-color:var(--gold)}
.limit-unit{font-size:9px;color:var(--text2);letter-spacing:1px}
.limit-active-badge{
  font-size:8px;font-family:var(--f-display);letter-spacing:1.5px;
  padding:2px 8px;border-radius:2px;
  background:rgba(255,140,0,0.1);color:var(--orange);
  border:1px solid rgba(255,140,0,0.3);
}

/* ═══ BALL DECORATIONS ON CARD ═══ */
.balls-deco{
  display:flex;gap:4px;
  padding:0 16px 0;
  align-items:center;
}
.ball{
  width:14px;height:14px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:6px;font-weight:700;color:rgba(255,255,255,0.8);
  box-shadow:inset -2px -2px 4px rgba(0,0,0,0.4),inset 1px 1px 2px rgba(255,255,255,0.2);
}
.ball-1{background:radial-gradient(circle at 35% 30%,#f5c800,#c89800)}
.ball-2{background:radial-gradient(circle at 35% 30%,#3366ff,#1133cc)}
.ball-3{background:radial-gradient(circle at 35% 30%,#cc2200,#881100)}
.ball-4{background:radial-gradient(circle at 35% 30%,#882299,#551166)}
.ball-5{background:radial-gradient(circle at 35% 30%,#ff6600,#cc4400)}
.ball-8{background:radial-gradient(circle at 35% 30%,#222,#111)}

/* ═══ DIVIDER ═══ */
.sep{height:1px;background:var(--border);margin:0}

/* ═══ EXTRAS ═══ */
.extras-section{border-top:1px solid var(--border);padding:8px 14px 10px}
.extras-head{display:flex;align-items:center;justify-content:space-between;cursor:pointer;user-select:none;margin-bottom:5px}
.extras-title{font-size:9px;color:var(--text2);text-transform:uppercase;letter-spacing:2px;display:flex;align-items:center;gap:5px}
.extras-total{font-family:var(--f-mono);font-size:11px;color:var(--gold)}
.extras-body{display:none}
.extras-body.open{display:block}
.product-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:5px;margin-bottom:8px}
.product-btn{
  background:#0a1018;border:1px solid var(--border2);
  border-radius:4px;padding:6px 8px;cursor:pointer;
  display:flex;align-items:center;justify-content:space-between;
  gap:5px;transition:all 0.12s;color:var(--text);
}
.product-btn:hover{border-color:var(--gold3);background:#0f1820}
.product-btn:active{transform:scale(0.97)}
.product-name{font-size:10px;color:var(--text);line-height:1.3;text-align:left;font-family:var(--f-ui)}
.product-price{font-family:var(--f-mono);font-size:10px;color:var(--gold);white-space:nowrap}
.extras-list{margin-top:5px}
.extra-item{
  display:flex;align-items:center;justify-content:space-between;
  padding:3px 0;border-bottom:1px solid rgba(23,32,48,0.6);
  font-size:11px;font-family:var(--f-mono);
}
.extra-item:last-child{border-bottom:none}
.extra-name{color:var(--text2);flex:1}
.extra-qty{display:flex;align-items:center;gap:3px;margin:0 7px}
.qty-btn{
  width:18px;height:18px;background:#111c28;
  border:1px solid var(--border2);border-radius:2px;
  color:var(--text);cursor:pointer;font-size:12px;
  display:flex;align-items:center;justify-content:center;padding:0;
}
.qty-btn:hover{border-color:var(--gold3);color:var(--gold)}
.qty-num{font-size:11px;min-width:14px;text-align:center;color:var(--text)}
.extra-sum{color:var(--gold);min-width:75px;text-align:right}
.extra-del{background:none;border:none;color:var(--red);cursor:pointer;font-size:12px;padding:0 0 0 5px;opacity:0.45}
.extra-del:hover{opacity:1}
.custom-extra{display:flex;gap:5px;margin-top:7px;align-items:center}
.custom-extra input{
  background:#060a10;border:1px solid var(--border2);color:var(--text);
  padding:4px 7px;border-radius:4px;font-size:11px;outline:none;
}
.custom-extra input:focus{border-color:var(--gold)}
.custom-extra input.name-in{flex:1;min-width:0}
.custom-extra input.price-in{width:75px}
.btn-add-custom{
  padding:4px 9px;background:rgba(212,168,67,0.08);
  border:1px solid rgba(212,168,67,0.3);color:var(--gold);
  border-radius:4px;cursor:pointer;font-size:11px;white-space:nowrap;
}
.btn-add-custom:hover{background:rgba(212,168,67,0.15)}

/* ═══ HISTORY ═══ */
.history-section{border-top:1px solid var(--border);padding:8px 14px 12px}
.history-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:5px}
.history-title{font-size:9px;color:var(--text2);text-transform:uppercase;letter-spacing:2.5px}
.btn-clear-hist{font-size:9px;color:var(--red);background:none;border:none;cursor:pointer;opacity:0.5;padding:0;letter-spacing:1px;text-transform:uppercase}
.btn-clear-hist:hover{opacity:1}
.hist-table{width:100%;border-collapse:collapse;font-size:11px;font-family:var(--f-mono)}
.hist-table th{color:var(--text2);font-weight:400;text-align:left;padding:3px 5px;border-bottom:1px solid var(--border);letter-spacing:1px;text-transform:uppercase;font-size:9px}
.hist-table td{padding:4px 5px;border-bottom:1px solid rgba(23,32,48,0.5);color:var(--text)}
.hist-table td.sum{color:var(--gold)}
.hist-table tr:last-child td{border-bottom:none}
.no-hist{text-align:center;color:var(--text2);font-size:10px;padding:6px 0;letter-spacing:1px}

/* ═══ ADD CARD ═══ */
.add-card{
  background:transparent;border:1px dashed var(--border2);
  border-radius:8px;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:10px;
  cursor:pointer;min-height:180px;color:var(--text2);
  transition:all 0.2s;
}
.add-card:hover{border-color:var(--gold3);color:var(--gold)}
.add-card span{font-size:28px;line-height:1}
.add-card p{font-size:11px;letter-spacing:3px;text-transform:uppercase;font-family:var(--f-display)}

/* ═══ ADMIN LOCK SCREEN ═══ */
.admin-lock{
  position:fixed;inset:0;z-index:9999;
  background:#040609;
  display:flex;align-items:center;justify-content:center;
  background-image:
    radial-gradient(ellipse 60% 60% at 50% 50%, rgba(0,115,40,0.06) 0%, transparent 65%),
    radial-gradient(ellipse 40% 40% at 50% 50%, rgba(212,168,67,0.04) 0%, transparent 50%);
}
.admin-box{
  width:400px;max-width:94vw;
  background:var(--surface);
  border:1px solid var(--gold3);
  border-radius:6px;
  padding:40px;
  box-shadow:0 0 80px rgba(212,168,67,0.1), 0 0 0 1px rgba(212,168,67,0.04);
  text-align:center;
}
.admin-balls{display:flex;justify-content:center;gap:8px;margin-bottom:20px}
.admin-ball{
  width:20px;height:20px;border-radius:50%;
  box-shadow:inset -3px -3px 5px rgba(0,0,0,0.5),inset 1px 1px 3px rgba(255,255,255,0.2);
}
.admin-box h2{
  font-family:var(--f-display);font-size:30px;
  color:var(--gold);letter-spacing:5px;
  margin-bottom:4px;
  text-shadow:0 0 30px rgba(212,168,67,0.3);
}
.admin-box p{color:var(--text2);margin-bottom:24px;font-size:12px;letter-spacing:2px;text-transform:uppercase}
.admin-box input{
  width:100%;background:#060a0d;
  border:1px solid var(--border2);color:var(--text);
  padding:13px;border-radius:4px;font-size:22px;
  font-family:var(--f-mono);margin-bottom:14px;
  outline:none;text-align:center;letter-spacing:8px;
}
.admin-box input:focus{border-color:var(--gold)}
.admin-error{color:var(--red);font-size:11px;margin-top:8px;display:none;letter-spacing:1px}

/* ═══ MODALS ═══ */
.modal-overlay{
  display:none;position:fixed;inset:0;
  background:rgba(0,0,0,0.92);z-index:500;
  align-items:center;justify-content:center;
}
.modal-overlay.open{display:flex}
.modal{
  background:var(--surface);border:1px solid var(--border2);
  border-radius:6px;padding:28px;width:440px;
  max-width:96vw;max-height:92vh;overflow-y:auto;
}
.modal h2{
  font-family:var(--f-display);font-size:20px;
  color:var(--gold);letter-spacing:3px;
  text-transform:uppercase;margin-bottom:18px;
}
