<script>
let RATE = parseFloat(localStorage.getItem('rate') || '40000');
let tableCount = parseInt(localStorage.getItem('tcount') || '3');
let ADMIN_CODE = localStorage.getItem('adminCode') || '838325';

document.getElementById('rateInput').value = RATE;
document.getElementById('tableCount').value = tableCount;
document.getElementById('mRate').value = RATE;
document.getElementById('mCount').value = tableCount;

let timers = [];

// Table limits stored per table id (minutes, 0 = no limit)
let TABLE_LIMITS = JSON.parse(localStorage.getItem('table_limits') || '{}');

function initTimers(){
  const old = timers.map(t=>({running:t.running,start:t.start,sec:t.sec,history:t.history,name:t.name,extras:t.extras}));
  timers = Array.from({length:tableCount},(_,i)=>({
    id:i,
    running: old[i]?.running||false,
    start: old[i]?.start||0,
    sec: old[i]?.sec||0,
    history: old[i]?.history || JSON.parse(localStorage.getItem('hist_'+i)||'[]'),
    name: old[i]?.name || 'STOL '+(i+1),
    extras: old[i]?.extras || []
  }));
}

function fmt(s){
  const h=Math.floor(s/3600);
  const m=Math.floor((s%3600)/60);
  const sc=s%60;
  if(h>0) return h+'h '+m.toString().padStart(2,'0')+'m';
  return m.toString().padStart(2,'0')+':'+sc.toString().padStart(2,'0');
}

function fmtUZS(n){return n.toLocaleString('uz-UZ')+' UZS'}

function getElapsed(t){
  return t.running ? t.sec + Math.floor((Date.now()-t.start)/1000) : t.sec;
}

function getLimitSec(id){
  const m = parseInt(TABLE_LIMITS[id]||0);
  return isNaN(m)||m<=0 ? 0 : m*60;
}

function cardClass(t){
  if(!t.running) return '';
  const el = getElapsed(t);
  const lim = getLimitSec(t.id);
  if(lim>0 && el>=lim) return 'running overtime';
  return 'running';
}

function statusText(t){
  if(!t.running) return "Bo'sh";
  const el = getElapsed(t);
  const lim = getLimitSec(t.id);
  if(lim>0 && el>=lim) return 'Muddati Tugadi!';
  return 'Faol';
}

function progressPct(elapsed, id){
  const lim = getLimitSec(id);
  if(lim>0) return Math.min(100,(elapsed/lim)*100);
  return Math.min(100,(elapsed/7200)*100);
}

function progressClass(elapsed, id){
  const lim = getLimitSec(id);
  if(lim>0){
    const pct=(elapsed/lim)*100;
    if(pct>=100) return 'over';
    if(pct>=80) return 'warn';
  }
  return '';
}

// Countdown display for limited tables
function countdownHTML(t, elapsed){
  const lim = getLimitSec(t.id);
  if(!lim || !t.running) return '';
  const remaining = lim - elapsed;
  if(remaining <= 0){
    return `<div class="countdown-display">
      <div class="countdown-lbl">Qoldi</div>
      <div class="countdown-val over">TUGDI!</div>
    </div>`;
  }
  const cls = remaining<=300?'warn':'';
  return `<div class="countdown-display">
    <div class="countdown-lbl">Qoldi</div>
    <div class="countdown-val ${cls}">${fmt(remaining)}</div>
  </div>`;
}

const BALLS = ['ball-1','ball-2','ball-3','ball-4','ball-5','ball-8'];
function ballsDeco(id){
  const b = BALLS[id % BALLS.length];
  return `<div class="balls-deco">
    <div class="ball ball-8">8</div>
    <div class="ball ${b}"></div>
    <div class="ball ball-1"></div>
  </div>`;
}

const extrasOpen = new Set();

function render(){
  const root = document.getElementById('timers');
  root.innerHTML = '';
  timers.forEach(t=>{
    const el = getElapsed(t);
    const cls = cardClass(t);
    const bilPrice = Math.round(el * RATE / 3600);
    const extrasTotal = t.extras.reduce((s,e)=>s+e.price*e.qty,0);
    const totalPrice = bilPrice + extrasTotal;
    const pct = progressPct(el, t.id);
    const pClass = progressClass(el, t.id);
    const lim = getLimitSec(t.id);
    const isOvertime = t.running && lim>0 && el>=lim;

    const extrasListHTML = t.extras.length===0 ? '' : `
      <div class="extras-list">
        ${t.extras.map((e,ei)=>`
          <div class="extra-item">
            <span class="extra-name">${e.name}</span>
            <div class="extra-qty">
              <button class="qty-btn" onclick="changeQty(${t.id},${ei},-1)">−</button>
              <span class="qty-num">${e.qty}</span>
              <button class="qty-btn" onclick="changeQty(${t.id},${ei},1)">+</button>
            </div>
            <span class="extra-sum">${fmtUZS(e.price*e.qty)}</span>
            <button class="extra-del" onclick="removeExtra(${t.id},${ei})">✕</button>
          </div>`).join('')}
      </div>`;

    const productsHTML = CATALOG.map((p,pi)=>`
      <button class="product-btn" onclick="addExtra(${t.id},${pi})">
        <span class="product-name">${p.emoji} ${p.name}</span>
        <span class="product-price">${(p.price/1000).toFixed(0)}k</span>
      </button>`).join('');

    const limitVal = TABLE_LIMITS[t.id] || '';
    const limitBadge = limitVal ? `<span class="limit-active-badge">⏱ ${limitVal} min</span>` : '';

    const div = document.createElement('div');
    div.className = 'card'+(cls?' '+cls:'');
    div.innerHTML = `
      <div class="pulse"></div>
      <div class="card-head">
        <span class="table-name" onclick="renameTable(${t.id})" title="Ismni o'zgartirish">${t.name}</span>
        <span class="status-pill">${statusText(t)}</span>
      </div>
      ${isOvertime?`<div class="overtime-alert show">⚠ Vaqt Tugadi — To'xtatish Kerak!</div>`:''}
      <div class="time-area">
        <div class="time-block">
          <div class="time-num">${fmt(el)}</div>
          <div class="time-meta">${t.running?'Hisoblashmoqda...':'To\'xtatildi'}</div>
        </div>
        ${countdownHTML(t, el)}
      </div>
      <div class="prog-wrap">
        <div class="prog-fill ${pClass}" style="width:${pct}%"></div>
      </div>
      <div class="price-row">
        <div class="price-detail">
          Bilyard<br><span>${fmtUZS(bilPrice)}</span>
          ${extrasTotal>0?`<br>Qo'shimcha<br><span style="color:var(--gold3)">${fmtUZS(extrasTotal)}</span>`:''}
        </div>
        <div>
          <div class="price-total-lbl">JAMI</div>
          <div class="price-total">${fmtUZS(totalPrice)}</div>
        </div>
      </div>
      <div class="limit-row">
        <label>⏱ Vaqt Chegarasi</label>
        <input class="limit-input" type="number" min="0" max="999" placeholder="—"
          value="${limitVal}"
          onchange="setLimit(${t.id}, this.value)"
          title="Daqiqada. 0 yoki bo'sh = cheklovsiz">
        <span class="limit-unit">min</span>
        ${limitBadge}
      </div>
      <div class="controls">
        <button class="btn-start${t.running?' active':''}" onclick="toggle(${t.id})">
          ${t.running?'⏹  STOP':'▶  START'}
        </button>
        <button class="btn-icon" onclick="resetTimer(${t.id})" title="Reset">↺</button>
        <button class="btn-icon" onclick="removeTable(${t.id})" title="O'chirish" style="color:var(--red);border-color:rgba(255,61,61,0.25)">✕</button>
      </div>

      <div class="extras-section">
        <div class="extras-head" onclick="toggleExtras(${t.id})">
          <span class="extras-title">🛒 Qo'shimchalar (${t.extras.length}) <span style="font-size:8px;opacity:0.4">▼</span></span>
          ${extrasTotal>0?`<span class="extras-total">${fmtUZS(extrasTotal)}</span>`:''}
        </div>
        <div class="extras-body" id="extras-${t.id}">
          <div class="product-grid">${productsHTML}</div>
          <div class="custom-extra">
            <input class="name-in" type="text" id="cname-${t.id}" placeholder="Boshqa mahsulot...">
            <input class="price-in" type="number" id="cprice-${t.id}" placeholder="Narx">
            <button class="btn-add-custom" onclick="addCustomExtra(${t.id})">+ Qo'sh</button>
          </div>
          ${extrasListHTML}
        </div>
      </div>

      <div class="history-section">
        <div class="history-head">
          <span class="history-title">Tarix (${t.history.length})</span>
          ${t.history.length?`<button class="btn-clear-hist" onclick="clearHistory(${t.id})">Tozalash</button>`:''}
        </div>
        ${t.history.length===0?`<div class="no-hist">Sessiya yo'q</div>`:
        `<table class="hist-table">
          <thead><tr><th>Vaqt</th><th>Summa</th><th>Sana</th></tr></thead>
          <tbody>${t.history.slice(0,4).map(h=>`
            <tr>
              <td>${h.time}</td>
              <td class="sum" title="${h.extras||''}">${h.sum}${h.extras?'<span style="color:var(--gold3);font-size:9px"> +</span>':''}</td>
              <td>${h.date}</td>
            </tr>`).join('')}
          </tbody>
        </table>`}
        ${t.history.length>4?`<div class="no-hist" style="margin-top:3px">...va yana ${t.history.length-4} ta</div>`:''}
      </div>`;

    root.appendChild(div);
    if(extrasOpen.has(t.id)){
      const eb = div.querySelector(`#extras-${t.id}`);
      if(eb) eb.classList.add('open');
    }
  });

  const addBtn = document.createElement('button');
  addBtn.className='add-card';
  addBtn.onclick=addTable;
  addBtn.innerHTML='<span>＋</span><p>Stol Qo\'sh</p>';
  root.appendChild(addBtn);

  updateStats();
}

function setLimit(id, val){
  const m = parseInt(val);
  if(isNaN(m)||m<=0) delete TABLE_LIMITS[id];
  else TABLE_LIMITS[id] = m;
  localStorage.setItem('table_limits', JSON.stringify(TABLE_LIMITS));
}

function toggle(id){
  const t = timers[id];
  if(t.running){
    t.sec += Math.floor((Date.now()-t.start)/1000);
    t.running = false;
    const bilPrice = Math.round(t.sec*RATE/3600);
    const extrasTotal = t.extras.reduce((s,e)=>s+e.price*e.qty,0);
    const extrasDesc = t.extras.length ? ' | '+t.extras.map(e=>`${e.name}×${e.qty}`).join(', ') : '';
    t.history.unshift({
      time: fmt(t.sec),
      sum: fmtUZS(bilPrice + extrasTotal),
      date: new Date().toLocaleString('uz-UZ'),
      extras: extrasDesc
    });
    localStorage.setItem('hist_'+id, JSON.stringify(t.history));
    t.sec = 0; t.extras = [];
  } else {
    t.start = Date.now(); t.running = true;
  }
  render();
}

function resetTimer(id){
  if(!confirm('Bu stolni noldan boshlaysizmi?')) return;
  const t = timers[id];
  if(t.running){
    t.sec += Math.floor((Date.now()-t.start)/1000);
    t.history.unshift({time:fmt(t.sec),sum:fmtUZS(Math.round(t.sec*RATE/3600)),date:new Date().toLocaleString('uz-UZ')+' (Reset)'});
    localStorage.setItem('hist_'+id, JSON.stringify(t.history));
  }
  t.running=false;t.start=0;t.sec=0;
  render();
}

function clearHistory(id){
  if(!confirm('Tarixi o\'chirilsin?')) return;
  timers[id].history=[];
  localStorage.removeItem('hist_'+id);
  render();
}

function stopAll(){
  if(!confirm('Barcha stollarni to\'xtatilsinmi?')) return;
  timers.forEach(t=>{ if(t.running) toggle(t.id); });
}

function updateStats(){
  document.getElementById('stat-active').textContent = timers.filter(t=>t.running).length;
  const today = timers.reduce((s,t)=>s+t.history.reduce((a,h)=>{const v=parseInt(h.sum.replace(/\D/g,''));return a+(isNaN(v)?0:v);},0),0);
  document.getElementById('stat-today').textContent = today>0?(today/1000).toFixed(0)+'k':0;
  const sessions = timers.reduce((s,t)=>s+t.history.length,0);
  document.getElementById('stat-sessions').textContent = sessions;
  const allTimes = timers.flatMap(t=>t.history).map(h=>{const[m,s2]=h.time.split(':').map(Number);return isNaN(m)||isNaN(s2)?0:m*60+s2;}).filter(v=>v>0);
  if(allTimes.length){
    const avg=Math.round(allTimes.reduce((a,b)=>a+b,0)/allTimes.length);
    document.getElementById('stat-avg').textContent=fmt(avg);
  } else {
    document.getElementById('stat-avg').textContent='—';
  }
}

function addTable(){
  timers.push({id:timers.length,running:false,start:0,sec:0,history:[],name:'STOL '+(timers.length+1),extras:[]});
  tableCount=timers.length;
  localStorage.setItem('tcount',tableCount);
  document.getElementById('tableCount').value=tableCount;
  render();
}

function removeTable(id){
  if(timers.length<=1){alert('Kamida 1 ta stol bo\'lishi kerak');return}
  if(!confirm(timers[id].name+' o\'chirilsinmi?')) return;
  timers.splice(id,1);
  timers.forEach((t,i)=>t.id=i);
  tableCount=timers.length;
  localStorage.setItem('tcount',tableCount);
  render();
}

function renameTable(id){
  const n=prompt('Yangi nom:',timers[id].name);
  if(n&&n.trim()){timers[id].name=n.trim().toUpperCase();render();}
}

function rebuildTables(){
  const n=parseInt(document.getElementById('tableCount').value);
  if(n<1||n>12)return;
  tableCount=n;localStorage.setItem('tcount',n);
  while(timers.length<n)timers.push({id:timers.length,running:false,start:0,sec:0,history:[],name:'STOL '+(timers.length+1),extras:[]});
  while(timers.length>n)timers.pop();
  timers.forEach((t,i)=>t.id=i);
  render();
}

function updateRate(){
  RATE=parseFloat(document.getElementById('rateInput').value)||40000;
  localStorage.setItem('rate',RATE);
}

function openSettings(){
  document.getElementById('mRate').value=RATE;
  document.getElementById('mCount').value=tableCount;
  renderCatalogEditor();
  document.getElementById('settingsModal').classList.add('open');
}

function applySettings(){
  RATE=parseFloat(document.getElementById('mRate').value)||40000;
  const nc=parseInt(document.getElementById('mCount').value)||3;
  localStorage.setItem('rate',RATE);
  document.getElementById('rateInput').value=RATE;
  document.getElementById('tableCount').value=nc;
  tableCount=nc;rebuildTables();
  closeModal('settingsModal');
}

function openExport(){
  const lines=['=== ASHURALI BILLIARD HISOBOT ===',new Date().toLocaleString('uz-UZ'),''];
  let totalRev=0,totalSess=0;
  timers.forEach(t=>{
    lines.push(`--- ${t.name} ---`);
    if(t.history.length===0){lines.push('  Sessiya yo\'q');return;}
    t.history.forEach(h=>{lines.push(`  ${h.date}  |  ${h.time}  |  ${h.sum}`);const v=parseInt(h.sum.replace(/\D/g,''));if(!isNaN(v))totalRev+=v;});
    totalSess+=t.history.length;lines.push('');
  });
  lines.push('----------------------------');
  lines.push(`Jami sessiyalar: ${totalSess}`);
  lines.push(`Jami daromad: ${fmtUZS(totalRev)}`);
  document.getElementById('exportContent').innerHTML=lines.map(l=>`<div>${l.replace(/ /g,'&nbsp;')}</div>`).join('');
  document.getElementById('exportModal').classList.add('open');
}

function copyReport(){
  const txt=document.getElementById('exportContent').innerText;
  navigator.clipboard.writeText(txt).then(()=>alert('Nusxa olindi!')).catch(()=>{});
}

function closeModal(id){document.getElementById(id).classList.remove('open')}

document.querySelectorAll('.modal-overlay').forEach(m=>{
